use crate::graph::nodes::{Node, Operator};
use crate::graph::nodes::{OperatorNode, TensorNode};
use crate::tensor::Tensor;

#[derive(Debug)]
pub struct Graph {
    edges: Vec<(usize, usize)>, // (Source, Destination)
    children: Vec<Graph>,
}

impl Graph {
    fn new(edges: Vec<(usize, usize)>) -> Self {
        Graph {
            edges,
            children: Vec::new(),
        }
    }
}

// NOTE: We are doing things in an arena, that is why it is okay not have refrences of edge nodes
// The problem in the general way is that if a node is dropped and it still had an edge that can
// run into undefined behaviour.And if we want to start dropping nodes, in that case we will
// have to keep references, so that we don't drop nodes that are being used in other graphs. For
// now all deletions should happen at the same time, or rather just let the program complete and
// never delete the nodes.
#[derive(Debug)]
pub struct GraphGroup {
    nodes: Vec<Node>,
    graphs: Vec<Graph>,
}

impl GraphGroup {
    fn new() -> Self {
        GraphGroup {
            nodes: Vec::new(),
            graphs: Vec::new(),
        }
    }

    fn num_of_nodes(&self) -> usize {
        self.nodes.len()
    }

    fn graph_latest_index(&self) -> usize {
        self.graphs.len() - 1
    }

    fn get_node_latest_index(&self) -> usize {
        self.nodes.len() - 1
    }

    fn add_graph(&mut self, edges: Vec<(usize, usize)>) -> usize {
        if !edges.is_empty() {
            assert!(
                edges
                    .iter()
                    .all(|x| x.0 < self.num_of_nodes() && x.1 < self.num_of_nodes()),
                "Graph inputs mismatch"
            );
        }
        // TODO: Check that graph does not have cycle
        self.graphs.push(Graph::new(edges));
        self.graph_latest_index()
    }

    fn add_tensor(&mut self, tensor: Tensor) -> usize {
        self.nodes.push(Node::Tensor(TensorNode::new(tensor)));
        self.get_node_latest_index()
        self.nodes.len() - 1
    }

    fn add_operator(
        &mut self,
        graph_index: usize,
        operator: Operator,
        mut operands: Vec<usize>,
    ) -> usize {
        assert!(operands.len() == operator.value());
        //TODO: remove this check for same elements later to have a + a also as valid
        operands.sort();
        operands.dedup();

        self.nodes.push(Node::Operator(OperatorNode::new(operator)));
        let operator_index = self.nodes.len() - 1;
        for operand in operands {
            self.graphs[graph_index]
                .edges
                .push((operand, operator_index));
        }
        self.nodes.push(Node::Buffer);
        let buffer_index = self.nodes.len() - 1;
        self.graphs[graph_index]
            .edges
            .push((operator_index, buffer_index));

        buffer_index
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::dtype::*;
    use crate::graph::nodes::*;
    use crate::shape_tracker::*;
    use crate::tensor::*;

    #[test]
    fn add_two_tensors() {
        let mut graph_group = GraphGroup::new();

        //                C
        //               ADD
        //  A [1, 2, 3, 4]  B [5, 6, 7, 8]

        let graph = graph_group.add_graph(vec![]);

        let a = Tensor::new(
            Dtype::Float32(vec![1.0, 2.0, 3.0, 4.0]),
            ShapeTracker::new(vec![4], vec![1]),
        );

        let b = Tensor::new(
            Dtype::Float32(vec![5.0, 6.0, 7.0, 8.0]),
            ShapeTracker::new(vec![4], vec![1]),
        );

        let a = graph_group.add_tensor(a);
        let b = graph_group.add_tensor(b);

        let c = graph_group.add_operator(graph, Operator::Add, vec![a, b]);

        let d = graph_group.add_operator(graph, Operator::Add, vec![c, a]);

        println!("Nodes: {:?}", graph_group);
        println!("Edges: {:?}", graph_group.graphs[graph].edges);
    }
}
